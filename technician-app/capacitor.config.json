{
  "appId": "com.weixiutong.technician",
  "appName": "云匠",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "npmClient": "npm",
  "version": "1.0.0",
  "server": {
    "androidScheme": "http",
    "allowNavigation": ["*"]
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#E67A2E"
    }
  }
}
